# DevProxy Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================

# Port to expose the proxy server on the host
DEVPROXY_SERVER_PORT=8080

# =============================================================================
# Horizontal Scaling (Optional - choose ONE method)
# =============================================================================

# --- Option 1: Redis Backplane ---
# Redis connection string for multi-instance deployments
# Leave empty to disable Redis backplane
REDIS_CONNECTION_STRING=

# Redis port (when using docker-compose.scaled.yml)
REDIS_PORT=6379

# Number of server replicas (when using docker-compose.scaled.yml)
DEVPROXY_SERVER_REPLICAS=2

# --- Option 2: Peer-to-Peer (No Redis) ---
# Configure peer servers via environment variables:
# Peers__0=http://server2:8080
# Peers__1=http://server3:8080
# Or use docker-compose.peers.yml for pre-configured setup

# =============================================================================
# Client Configuration (only needed when running with --profile client)
# =============================================================================

# Proxy server URL
# Use http://devproxy-server:8080 when running both in Docker
# Use https://proxy.example.com when connecting to external server
DEVPROXY_SERVER=http://devproxy-server:8080

# Unique client ID for this tunnel
DEVPROXY_CLIENT_ID=my-dev-machine

# Local service URL to forward requests to
# Use host.docker.internal to access services on the Docker host
DEVPROXY_LOCAL_URL=http://host.docker.internal:5000
