# DevProxy Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================

# Port to expose the proxy server on the host
DEVPROXY_SERVER_PORT=8080

# =============================================================================
# Client Configuration (only needed when running with --profile client)
# =============================================================================

# Proxy server URL
# Use http://devproxy-server:8080 when running both in Docker
# Use https://proxy.example.com when connecting to external server
DEVPROXY_SERVER=http://devproxy-server:8080

# Unique client ID for this tunnel
DEVPROXY_CLIENT_ID=my-dev-machine

# Local service URL to forward requests to
# Use host.docker.internal to access services on the Docker host
DEVPROXY_LOCAL_URL=http://host.docker.internal:5000
